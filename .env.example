# Server
PORT=5000
NODE_ENV=development

# ML Engine (FastAPI) URL — required for training and results
ML_ENGINE_URL=http://localhost:8001

# Timeout for proxy requests to ML engine (ms). Increase for long-running jobs.
ML_REQUEST_TIMEOUT_MS=60000

# Optional: CORS origin (e.g. https://app.example.com). Leave empty for same-origin only.
# CORS_ORIGIN=
